<%- include('partials/header') %>
<div class="page-header">
  <h1>Dashboard</h1>
</div>

<div class="stats-grid">
  <a href="/staff" class="stat-card">
    <div class="stat-icon stat-blue">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
    </div>
    <div class="stat-body">
      <div class="stat-number"><%= stats.activeStaff %></div>
      <div class="stat-label">Active Staff</div>
    </div>
  </a>
  <a href="/doors" class="stat-card">
    <div class="stat-icon stat-slate">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
    </div>
    <div class="stat-body">
      <div class="stat-number"><%= stats.doors %></div>
      <div class="stat-label">Doors</div>
    </div>
  </a>
  <a href="/key-systems" class="stat-card">
    <div class="stat-icon stat-purple">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/></svg>
    </div>
    <div class="stat-body">
      <div class="stat-number"><%= stats.keySystems %></div>
      <div class="stat-label">Key Systems</div>
    </div>
  </a>
  <a href="/keys" class="stat-card">
    <div class="stat-icon stat-cyan">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m21 2-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0 3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
    </div>
    <div class="stat-body">
      <div class="stat-number"><%= stats.keys %></div>
      <div class="stat-label">Keys</div>
    </div>
  </a>
  <a href="/fob-profiles" class="stat-card">
    <div class="stat-icon stat-orange">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>
    </div>
    <div class="stat-body">
      <div class="stat-number"><%= stats.fobProfiles %></div>
      <div class="stat-label">FOB Profiles</div>
    </div>
  </a>
  <a href="/keytrak" class="stat-card">
    <div class="stat-icon stat-teal">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="8" cy="15" r="4"/><path d="M12 15h8M16 11v8"/></svg>
    </div>
    <div class="stat-body">
      <div class="stat-number"><%= stats.keyrings %></div>
      <div class="stat-label">Physical Keyrings</div>
    </div>
  </a>
  <a href="/floor-plans" class="stat-card">
    <div class="stat-icon stat-rose">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="1"/><path d="M3 9h18M9 21V9"/></svg>
    </div>
    <div class="stat-body">
      <div class="stat-number"><%= stats.floorPlans %></div>
      <div class="stat-label">Floor Plans</div>
    </div>
  </a>
  <a href="/safes" class="stat-card">
    <div class="stat-icon stat-green">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="12" cy="12" r="3"/></svg>
    </div>
    <div class="stat-body">
      <div class="stat-number"><%= stats.safes %></div>
      <div class="stat-label">Safes</div>
    </div>
  </a>
  <a href="/system-accounts" class="stat-card">
    <div class="stat-icon stat-indigo">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
    </div>
    <div class="stat-body">
      <div class="stat-number"><%= stats.systemAccounts %></div>
      <div class="stat-label">Shared Logins</div>
    </div>
  </a>
</div>

<div class="card">
  <div class="card-header">
    <h2>Recent Audit Activity</h2>
    <a href="/audit" class="btn btn-sm btn-outline">View All</a>
  </div>
  <% if (recentAudit.length === 0) { %>
    <p class="empty-state">No audit entries yet.</p>
  <% } else { %>
  <table class="table">
    <thead>
      <tr><th>When</th><th>Action</th><th>Resource</th><th>Staff / Detail</th><th>By</th></tr>
    </thead>
    <tbody>
      <% recentAudit.forEach(entry => { %>
      <tr>
        <td class="text-muted text-sm nowrap"><%= entry.performed_at %></td>
        <td><span class="badge badge-<%= entry.action === 'GRANT' ? 'green' : entry.action === 'REVOKE' ? 'red' : 'gray' %>"><%= entry.action %></span></td>
        <td><span class="badge badge-outline"><%= entry.resource_type %></span> <%= entry.resource_name || '' %></td>
        <td><%= entry.staff_name || entry.notes || '—' %></td>
        <td class="text-muted"><%= entry.performed_by %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>
<%- include('partials/footer') %>
