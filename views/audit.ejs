<%- include('partials/header') %>
<div class="page-header">
  <h1>Audit Log</h1>
</div>

<div class="card">
  <form class="filter-bar" method="GET" action="/audit" style="flex-wrap:wrap;gap:0.5rem;">
    <input type="text" name="q" placeholder="Search resource, staff, or notes…" value="<%= filters.q || '' %>" style="min-width:200px;">

    <select name="action">
      <option value="">All Actions</option>
      <% [
        ['CREATE','Create'],['UPDATE','Update'],['DELETE','Delete'],
        ['GRANT','Grant'],['REVOKE','Revoke'],
        ['TERMINATE','Terminate'],['REACTIVATE','Reactivate'],
        ['ASSIGN_KEY','Assign Key'],['REMOVE_KEY','Remove Key'],
        ['ASSIGN_FOB','Assign FOB'],['REMOVE_FOB','Remove FOB'],
        ['ADD_DOOR','Add Door'],['REMOVE_DOOR','Remove Door'],
        ['CHECKOUT','Checkout'],['CHECKIN','Check-in'],
        ['ISSUE','Issue'],['RETURN','Return'],
        ['LOST','Lost'],['DAMAGED','Damaged'],['DESTROYED','Destroyed'],['REPLACE','Replace'],
        ['CREATE_USER','Create Admin User'],['DELETE_USER','Delete Admin User'],['CHANGE_PASSWORD','Change Password'],
        ['VIEW_SECRET','View Secret'],
      ].forEach(([val, label]) => { %>
        <option value="<%= val %>" <%= filters.action === val ? 'selected' : '' %>><%= label %></option>
      <% }); %>
    </select>

    <select name="resource_type">
      <option value="">All Types</option>
      <% [
        ['STAFF','Staff'],['SAFE','Safe'],['KEYRING','Keyring'],
        ['SYSTEM_ACCOUNT','System Account'],['ADMIN_USER','Admin User'],
        ['KEY_SYSTEM','Key System'],['KEY','Key'],['DOOR','Door'],
        ['FOB_PROFILE','FOB Profile'],['PHYSICAL_KEY','Physical Key'],
      ].forEach(([val, label]) => { %>
        <option value="<%= val %>" <%= filters.resource_type === val ? 'selected' : '' %>><%= label %></option>
      <% }); %>
    </select>

    <select name="performed_by">
      <option value="">All Users</option>
      <% performers.forEach(u => { %>
        <option value="<%= u %>" <%= filters.performed_by === u ? 'selected' : '' %>><%= u %></option>
      <% }); %>
    </select>

    <input type="date" name="date_from" value="<%= filters.date_from || '' %>" title="From date" style="width:140px;">
    <input type="date" name="date_to"   value="<%= filters.date_to   || '' %>" title="To date"   style="width:140px;">

    <select name="limit">
      <option value="100"  <%= limit == 100  ? 'selected' : '' %>>Last 100</option>
      <option value="250"  <%= limit == 250  ? 'selected' : '' %>>Last 250</option>
      <option value="500"  <%= limit == 500  ? 'selected' : '' %>>Last 500</option>
      <option value="1000" <%= limit == 1000 ? 'selected' : '' %>>Last 1 000</option>
      <option value="2000" <%= limit == 2000 ? 'selected' : '' %>>Last 2 000</option>
    </select>

    <button type="submit" class="btn btn-outline">Filter</button>
    <a href="/audit" class="btn btn-ghost">Reset</a>
    <a href="/audit/export?<%= new URLSearchParams(Object.fromEntries(Object.entries(filters).filter(([,v])=>v))).toString() %>" class="btn btn-ghost">Export CSV</a>
  </form>

  <% if (entries.length === 0) { %>
    <p class="empty-state">No audit entries match your filters.</p>
  <% } else { %>
  <p class="text-muted text-sm" style="padding: 0 1.5rem 0.5rem;">Showing <%= entries.length %> entries</p>
  <table class="table">
    <thead>
      <tr>
        <th>Timestamp</th>
        <th>Action</th>
        <th>Resource Type</th>
        <th>Resource</th>
        <th>Staff Member</th>
        <th>Performed By</th>
        <th>Notes</th>
      </tr>
    </thead>
    <tbody>
      <% entries.forEach(e => {
        const actionColor = {
          GRANT: 'green', REACTIVATE: 'green', CREATE: 'blue', CREATE_USER: 'blue',
          REVOKE: 'red', TERMINATE: 'red', DELETE: 'red', DELETE_USER: 'red',
          LOST: 'red', DAMAGED: 'red', DESTROYED: 'red',
          UPDATE: 'yellow', CHANGE_PASSWORD: 'yellow', REPLACE: 'yellow',
          ISSUE: 'teal', CHECKOUT: 'teal', ASSIGN_KEY: 'teal', ASSIGN_FOB: 'teal', ADD_DOOR: 'teal',
          RETURN: 'gray', CHECKIN: 'gray', REMOVE_KEY: 'gray', REMOVE_FOB: 'gray', REMOVE_DOOR: 'gray',
          VIEW_SECRET: 'purple',
        }[e.action] || 'gray';
      %>
      <tr>
        <td class="text-muted text-sm nowrap"><%= e.performed_at %></td>
        <td><span class="badge badge-<%= actionColor %>"><%= e.action %></span></td>
        <td><span class="badge badge-outline"><%= e.resource_type %></span></td>
        <td><%= e.resource_name || '—' %></td>
        <td>
          <% if (e.staff_id) { %>
            <a href="/staff/<%= e.staff_id %>"><%= e.staff_name %></a>
          <% } else { %>
            <%= e.staff_name || '—' %>
          <% } %>
        </td>
        <td class="text-muted"><%= e.performed_by %></td>
        <td class="text-muted text-sm"><%= e.notes || '' %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>
<%- include('partials/footer') %>
