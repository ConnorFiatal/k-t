<%- include('partials/header') %>
<div class="page-header">
  <h1>Audit Log</h1>
</div>

<div class="card">
  <form class="filter-bar" method="GET" action="/audit">
    <input type="text" name="q" placeholder="Search resource or staff…" value="<%= filters.q || '' %>">
    <select name="action">
      <option value="">All Actions</option>
      <option value="GRANT" <%= filters.action === 'GRANT' ? 'selected' : '' %>>GRANT</option>
      <option value="REVOKE" <%= filters.action === 'REVOKE' ? 'selected' : '' %>>REVOKE</option>
      <option value="TERMINATE" <%= filters.action === 'TERMINATE' ? 'selected' : '' %>>TERMINATE</option>
    </select>
    <select name="resource_type">
      <option value="">All Types</option>
      <option value="SAFE" <%= filters.resource_type === 'SAFE' ? 'selected' : '' %>>Safe</option>
      <option value="KEYRING" <%= filters.resource_type === 'KEYRING' ? 'selected' : '' %>>Keyring</option>
      <option value="SYSTEM_ACCOUNT" <%= filters.resource_type === 'SYSTEM_ACCOUNT' ? 'selected' : '' %>>System Account</option>
      <option value="STAFF" <%= filters.resource_type === 'STAFF' ? 'selected' : '' %>>Staff</option>
    </select>
    <select name="limit">
      <option value="100" <%= limit == 100 ? 'selected' : '' %>>Last 100</option>
      <option value="250" <%= limit == 250 ? 'selected' : '' %>>Last 250</option>
      <option value="500" <%= limit == 500 ? 'selected' : '' %>>Last 500</option>
    </select>
    <button type="submit" class="btn btn-outline">Filter</button>
    <a href="/audit" class="btn btn-ghost">Reset</a>
  </form>

  <% if (entries.length === 0) { %>
    <p class="empty-state">No audit entries match your filters.</p>
  <% } else { %>
  <p class="text-muted text-sm" style="padding: 0 1.5rem 0.5rem;">Showing <%= entries.length %> entries</p>
  <table class="table">
    <thead>
      <tr>
        <th>Timestamp</th>
        <th>Action</th>
        <th>Resource Type</th>
        <th>Resource</th>
        <th>Staff Member</th>
        <th>Performed By</th>
        <th>Notes</th>
      </tr>
    </thead>
    <tbody>
      <% entries.forEach(e => { %>
      <tr>
        <td class="text-muted text-sm nowrap"><%= e.performed_at %></td>
        <td><span class="badge badge-<%= e.action === 'GRANT' ? 'green' : e.action === 'REVOKE' ? 'red' : 'gray' %>"><%= e.action %></span></td>
        <td><span class="badge badge-outline"><%= e.resource_type %></span></td>
        <td><%= e.resource_name || '—' %></td>
        <td>
          <% if (e.staff_id) { %>
            <a href="/staff/<%= e.staff_id %>"><%= e.staff_name %></a>
          <% } else { %>
            <%= e.staff_name || '—' %>
          <% } %>
        </td>
        <td class="text-muted"><%= e.performed_by %></td>
        <td class="text-muted text-sm"><%= e.notes || '' %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>
<%- include('partials/footer') %>
