<%- include('../partials/header') %>
<div class="page-header">
  <h1>Report: Key Directory</h1>
  <div class="btn-group">
    <button class="btn btn-outline no-print print-btn">Print</button>
    <a href="/reports" class="btn btn-ghost no-print">← Reports</a>
  </div>
</div>

<div class="card">
  <form class="filter-bar" method="GET" action="/reports/key-directory">
    <select name="system_id">
      <option value="">All Systems</option>
      <% systems.forEach(s => { %>
        <option value="<%= s.id %>" <%= filters.system_id == s.id ? 'selected' : '' %>><%= s.name %></option>
      <% }) %>
    </select>
    <select name="level">
      <option value="">All Levels</option>
      <% Object.entries(LEVEL_LABEL).forEach(([k,v]) => { %>
        <option value="<%= k %>" <%= filters.level === k ? 'selected' : '' %>><%= v %></option>
      <% }) %>
    </select>
    <button type="submit" class="btn btn-outline">Filter</button>
    <a href="/reports/key-directory" class="btn btn-ghost">Reset</a>
  </form>

  <p class="report-count"><%= keys.length %> key<%= keys.length !== 1 ? 's' : '' %></p>

  <% if (keys.length === 0) { %>
    <p class="empty-state">No keys match the selected filters.</p>
  <% } else { %>
  <table class="table">
    <thead>
      <tr><th>Key #</th><th>System</th><th>Level</th><th>Parent Key</th><th>Bitting</th><th>Keyway</th><th>Key Blank</th><th>Doors</th><th>Rings</th></tr>
    </thead>
    <tbody>
      <% keys.forEach(k => { %>
      <tr>
        <td><a href="/keys/<%= k.id %>"><strong><%= k.key_number %></strong></a></td>
        <td><a href="/key-systems/<%= k.key_system_id %>" class="text-muted"><%= k.system_name %></a></td>
        <td><span class="badge badge-level-<%= (k.level||'CHANGE').toLowerCase() %>"><%= LEVEL_LABEL[k.level] || k.level %></span></td>
        <td class="text-muted"><%= k.parent_number || '—' %></td>
        <td>
          <% if (k.bitting) { %>
            <span class="secret-value" data-secret="<%= k.bitting %>">••••••</span>
            <button type="button" class="btn btn-sm btn-ghost toggle-secret">Show</button>
          <% } else { %><span class="text-muted">—</span><% } %>
        </td>
        <td class="text-muted"><%= k.keyway || k.system_keyway || '—' %></td>
        <td class="text-muted"><%= k.key_blank || '—' %></td>
        <td><span class="count-badge"><%= k.door_count %></span></td>
        <td><span class="count-badge"><%= k.ring_count %></span></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>


<%- include('../partials/footer') %>
