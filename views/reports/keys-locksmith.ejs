<%- include('../partials/header') %>
<div class="page-header">
  <h1>Report: Locksmith Transaction History</h1>
  <div class="btn-group">
    <button onclick="window.print()" class="btn btn-outline no-print">Print</button>
    <a href="/reports/keys/locksmith-history.csv<%= filters.from_date || filters.to_date ? '?from_date='+filters.from_date+'&to_date='+filters.to_date : '' %>" class="btn btn-outline no-print">↓ CSV</a>
    <a href="/reports/keys" class="btn btn-ghost no-print">← Reports</a>
  </div>
</div>

<div class="card" style="margin-bottom:1rem">
  <form class="filter-bar no-print" method="GET" action="/reports/keys/locksmith-history">
    <div class="filter-group">
      <label class="filter-label">From</label>
      <input type="date" name="from_date" value="<%= filters.from_date %>">
    </div>
    <div class="filter-group">
      <label class="filter-label">To</label>
      <input type="date" name="to_date" value="<%= filters.to_date %>">
    </div>
    <button type="submit" class="btn btn-outline">Filter</button>
    <a href="/reports/keys/locksmith-history" class="btn btn-ghost">Reset</a>
  </form>
</div>

<p class="report-count"><%= rows.length %> transaction<%= rows.length !== 1 ? 's' : '' %></p>

<% if (rows.length === 0) { %>
  <div class="card"><p class="empty-state">No locksmith transactions found.</p></div>
<% } else { %>
<div class="card">
  <table class="table">
    <thead>
      <tr><th>Date</th><th>Type</th><th>Stamp #</th><th>Key Type</th><th>System</th><th>Linked Key</th><th>By</th><th>Receipt</th><th>Notes</th></tr>
    </thead>
    <tbody>
      <% rows.forEach(r => { %>
      <tr>
        <td class="text-muted text-sm"><%= r.transaction_date %></td>
        <td><span class="badge badge-tx-<%= r.transaction_type.replace(/_/g,'-') %>"><%= r.transaction_type.replace(/_/g,' ') %></span></td>
        <td><a href="/physical-keys/<%= r.physical_key_id %>"><strong><%= r.stamp_number %></strong></a></td>
        <td class="text-muted"><%= r.key_number %></td>
        <td class="text-muted"><%= r.system_name %></td>
        <td class="text-muted">
          <% if (r.linked_stamp) { %><a href="/physical-keys/<%= r.linked_key_id %>"><%= r.linked_stamp %></a><% } else { %>—<% } %>
        </td>
        <td class="text-muted text-sm"><%= r.performed_by %></td>
        <td>
          <% if (r.receipt_filename) { %>
            <a href="/uploads/receipts/<%= r.receipt_filename %>" target="_blank" class="btn btn-sm btn-outline">📎 View</a>
          <% } else { %><span class="text-muted">—</span><% } %>
        </td>
        <td class="text-muted text-sm"><%= r.notes || '—' %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<% } %>
<%- include('../partials/footer') %>
