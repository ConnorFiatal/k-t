<%- include('../partials/header') %>
<div class="page-header">
  <h1>Reports</h1>
</div>

<div class="reports-grid">
  <a href="/reports/key-directory" class="report-card">
    <div class="report-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m21 2-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0 3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
    </div>
    <div class="report-body">
      <h3>Key Directory</h3>
      <p>All keys with bitting, keyway, key blank, level, and system. Filterable by system or level.</p>
    </div>
  </a>

  <a href="/reports/door-schedule" class="report-card">
    <div class="report-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
    </div>
    <div class="report-body">
      <h3>Door Schedule</h3>
      <p>Every door with its access type, all keys that open it, and all FOB profiles that cover it.</p>
    </div>
  </a>

  <a href="/reports/keyring-inventory" class="report-card">
    <div class="report-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="8" cy="15" r="4"/><path d="M12 15h8M16 11v8"/></svg>
    </div>
    <div class="report-body">
      <h3>Keyring Inventory</h3>
      <p>Full contents of every keyring: authorized staff, physical keys, and FOB credentials.</p>
    </div>
  </a>

  <a href="/reports/staff-access" class="report-card">
    <div class="report-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
    </div>
    <div class="report-body">
      <h3>Staff Access Summary</h3>
      <p>All access per staff member: keyrings, safe combinations, and system accounts.</p>
    </div>
  </a>

  <a href="/reports/master-system-map" class="report-card">
    <div class="report-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/></svg>
    </div>
    <div class="report-body">
      <h3>Master System Map</h3>
      <p>Topographical hierarchy tree showing GMK → MK → Sub-Master → Change key relationships.</p>
    </div>
  </a>

  <a href="/reports/fob-profiles" class="report-card">
    <div class="report-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>
    </div>
    <div class="report-body">
      <h3>FOB Profile Directory</h3>
      <p>All FOB profiles with their complete door lists and keyring assignments.</p>
    </div>
  </a>

  <a href="/reports/access-by-door" class="report-card">
    <div class="report-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/><circle cx="12" cy="16" r="1"/></svg>
    </div>
    <div class="report-body">
      <h3>Access by Door</h3>
      <p>For each door, which staff can access it — via key on a keyring or FOB profile.</p>
    </div>
  </a>
</div>
