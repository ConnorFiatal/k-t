<%- include('../partials/header') %>
<div class="page-header">
  <h1>Report: FOB Profile Directory</h1>
  <div class="btn-group">
    <button class="btn btn-outline no-print print-btn">Print</button>
    <a href="/reports" class="btn btn-ghost no-print">← Reports</a>
  </div>
</div>

<p class="report-count"><%= profiles.length %> profile<%= profiles.length !== 1 ? 's' : '' %></p>

<% if (profiles.length === 0) { %>
  <div class="card"><p class="empty-state">No FOB profiles configured.</p></div>
<% } else { %>
  <% profiles.forEach(p => { %>
  <div class="card report-section">
    <div class="card-header">
      <h2><a href="/fob-profiles/<%= p.id %>"><%= p.name %></a></h2>
      <span class="text-muted text-sm"><%= p.description || '' %></span>
    </div>
    <div class="report-section-body">

      <div class="report-col">
        <h4 class="report-col-label">Doors Covered (<%= p.doors.length %>)</h4>
        <% if (p.doors.length === 0) { %>
          <p class="text-muted text-sm">No doors assigned.</p>
        <% } else { %>
          <ul class="report-list">
            <% p.doors.forEach(d => { %>
              <li>
                <span class="badge badge-access-<%= d.access_type.toLowerCase() %>"><%= d.access_type %></span>
                <a href="/doors/<%= d.id %>"><%= d.name %></a>
                <% if (d.door_number) { %><span class="text-muted text-sm"> (#<%= d.door_number %>)</span><% } %>
                <% if (d.building) { %><span class="text-muted text-sm"> · <%= d.building %><% if (d.floor) { %>, <%= d.floor %><% } %></span><% } %>
              </li>
            <% }) %>
          </ul>
        <% } %>
      </div>

      <div class="report-col">
        <h4 class="report-col-label">Assigned to Keyrings (<%= p.rings.length %>)</h4>
        <% if (p.rings.length === 0) { %>
          <p class="text-muted text-sm">Not on any keyring.</p>
        <% } else { %>
          <ul class="report-list">
            <% p.rings.forEach(r => { %>
              <li>
                <a href="/keytrak/<%= r.keyring_id %>">Ring <%= r.ring_number %></a>
                <% if (r.fob_serial) { %><span class="text-muted text-sm"> · S/N: <%= r.fob_serial %></span><% } %>
              </li>
            <% }) %>
          </ul>
        <% } %>
      </div>

    </div>
  </div>
  <% }) %>
<% } %>
<%- include('../partials/footer') %>
