<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .demo-page {
      min-height: 100vh;
      background: var(--sidebar-bg);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem 1rem;
    }
    .demo-header {
      text-align: center;
      margin-bottom: 2.5rem;
    }
    .demo-brand {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      color: #e2e8f0;
      font-size: 1.5rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 0.5rem;
    }
    .demo-brand svg { color: var(--blue); }
    .demo-badge {
      display: inline-block;
      background: rgba(234,179,8,0.15);
      color: #fbbf24;
      border: 1px solid rgba(234,179,8,0.3);
      border-radius: 999px;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      padding: 2px 10px;
      margin-bottom: 1rem;
    }
    .demo-header h2 {
      color: #e2e8f0;
      font-size: 1.25rem;
      font-weight: 600;
      margin-bottom: 0.4rem;
    }
    .demo-header p {
      color: #94a3b8;
      font-size: 0.9rem;
      max-width: 420px;
    }
    .demo-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
      width: 100%;
      max-width: 680px;
    }
    @media (max-width: 580px) {
      .demo-grid { grid-template-columns: 1fr; }
    }
    .role-card {
      background: #243447;
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 12px;
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      transition: border-color 0.15s, transform 0.1s;
      cursor: pointer;
    }
    .role-card:hover {
      border-color: rgba(255,255,255,0.18);
      transform: translateY(-2px);
    }
    .role-icon {
      width: 40px;
      height: 40px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .role-icon svg { width: 20px; height: 20px; }
    .role-tag {
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 2px 8px;
      border-radius: 999px;
      display: inline-block;
    }
    .role-name {
      color: #e2e8f0;
      font-size: 1.0625rem;
      font-weight: 600;
      margin: 0;
    }
    .role-desc {
      color: #94a3b8;
      font-size: 0.825rem;
      line-height: 1.55;
      flex: 1;
    }
    .role-btn {
      width: 100%;
      padding: 0.6rem 1rem;
      border: none;
      border-radius: 7px;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      transition: filter 0.15s;
      color: #fff;
    }
    .role-btn:hover { filter: brightness(1.12); }
    .demo-footer {
      margin-top: 2rem;
      text-align: center;
      color: #475569;
      font-size: 0.8rem;
      max-width: 480px;
      line-height: 1.6;
    }
    .flash { margin-bottom: 1.5rem; max-width: 680px; width: 100%; }
  </style>
</head>
<body class="demo-page">

  <% if (flash && flash.error) { %>
    <div class="flash flash-error"><%= flash.error %></div>
  <% } %>

  <div class="demo-header">
    <div class="demo-brand">
      <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="3" y="11" width="18" height="11" rx="2"/>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
      </svg>
      KeyDog
    </div>
    <span class="demo-badge">LIVE DEMO</span>
    <h2>Choose a role to explore</h2>
    <p>All features are enabled. Data is preloaded with a realistic example organisation. Pick a role to see what that user can do.</p>
  </div>

  <div class="demo-grid">
    <% for (const role of roles) { %>
    <form action="/demo/select" method="POST">
      <input type="hidden" name="role" value="<%= role.name %>">
      <button type="submit" class="role-card" style="text-align:left;background:#243447;width:100%">
        <div style="display:flex;align-items:center;justify-content:space-between">
          <div class="role-icon" style="background:<%- role.color %>1a;color:<%- role.color %>">
            <%- role.icon %>
          </div>
          <span class="role-tag" style="background:<%- role.color %>1a;color:<%- role.color %>">
            <%= role.tagline %>
          </span>
        </div>
        <p class="role-name"><%= role.label %></p>
        <p class="role-desc"><%= role.description %></p>
        <div class="role-btn" style="background:<%- role.color %>">
          Explore as <%= role.label %> &rarr;
        </div>
      </button>
    </form>
    <% } %>
  </div>

  <p class="demo-footer">
    This is a demonstration environment. Changes you make are saved to a local database and will persist within this session. No real credentials or access is granted.
  </p>

</body>
</html>
