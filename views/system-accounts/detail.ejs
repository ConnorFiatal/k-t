<%- include('../partials/header') %>
<div class="page-header">
  <div>
    <h1><%= account.system_name %></h1>
    <p class="text-muted"><%= account.account_username %><%= account.category ? ` · ${account.category}` : '' %></p>
  </div>
  <div class="btn-group">
    <a href="/system-accounts/<%= account.id %>/edit" class="btn btn-outline">Edit</a>
    <a href="/system-accounts" class="btn btn-ghost">← Back</a>
  </div>
</div>

<div class="detail-grid">
  <div class="card">
    <div class="card-header"><h2>Account Details</h2></div>
    <table class="info-table">
      <tr><th>System</th><td><%= account.system_name %></td></tr>
      <tr><th>Category</th><td><%= account.category ? `<span class="badge badge-outline">${account.category}</span>` : '—' %></td></tr>
      <tr><th>Username</th><td><code><%= account.account_username %></code></td></tr>
      <tr>
        <th>Password</th>
        <td>
          <% if (account.account_password) { %>
            <%# Issue 1 — password is NOT in the HTML; fetched on demand via authenticated endpoint %>
            <span class="secret-value" data-id="<%= account.id %>">••••••••</span>
            <button type="button" class="btn btn-sm btn-ghost toggle-secret">Show</button>
          <% } else { %>
            <span class="text-muted">Not stored</span>
          <% } %>
        </td>
      </tr>
      <% if (account.url) { %>
      <tr><th>URL</th><td><a href="<%= account.url %>" target="_blank" rel="noopener"><%= account.url %></a></td></tr>
      <% } %>
      <tr><th>Added</th><td><%= account.created_at %></td></tr>
      <% if (account.notes) { %><tr><th>Notes</th><td><%= account.notes %></td></tr><% } %>
    </table>
  </div>

  <div class="card">
    <div class="card-header">
      <h2>Staff with Access <span class="count-badge"><%= access.length %></span></h2>
    </div>

    <% if (eligibleStaff.length > 0) { %>
    <form action="/system-accounts/<%= account.id %>/grant" method="POST" class="grant-form">
      <select name="staff_id" required>
        <option value="">— Select staff member —</option>
        <% eligibleStaff.forEach(s => { %>
          <option value="<%= s.id %>"><%= s.last_name %>, <%= s.first_name %><%= s.department ? ` (${s.department})` : '' %></option>
        <% }) %>
      </select>
      <button type="submit" class="btn btn-primary">Grant Access</button>
    </form>
    <% } else { %>
      <p class="empty-state-sm text-muted">All active staff already have access.</p>
    <% } %>

    <% if (access.length === 0) { %>
      <p class="empty-state-sm">No staff have access yet.</p>
    <% } else { %>
    <table class="table">
      <thead><tr><th>Name</th><th>Department</th><th>Granted</th><th>By</th><th></th></tr></thead>
      <tbody>
        <% access.forEach(a => { %>
        <tr class="<%= a.status === 'terminated' ? 'row-terminated' : '' %>">
          <td><a href="/staff/<%= a.staff_id %>"><%= a.last_name %>, <%= a.first_name %></a>
            <% if (a.status === 'terminated') { %><span class="badge badge-red badge-sm">terminated</span><% } %>
          </td>
          <td class="text-muted"><%= a.department || '—' %></td>
          <td class="text-muted text-sm"><%= a.granted_at %></td>
          <td class="text-muted"><%= a.granted_by %></td>
          <td class="text-right">
            <form action="/system-accounts/<%= account.id %>/revoke/<%= a.staff_id %>" method="POST" style="display:inline">
              <button type="submit" class="btn btn-sm btn-danger" data-confirm="Revoke access for <%= a.first_name %> <%= a.last_name %>?">Revoke</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>
</div>

<script>
document.querySelectorAll('.toggle-secret').forEach(btn => {
  btn.addEventListener('click', async function () {
    const span = this.previousElementSibling;
    if (this.textContent === 'Show') {
      this.disabled = true;
      this.textContent = '…';
      try {
        const resp = await fetch(`/system-accounts/${span.dataset.id}/secret`);
        if (!resp.ok) throw new Error('Failed to load');
        const { password } = await resp.json();
        span.textContent = password || '(empty)';
        this.textContent = 'Hide';
      } catch (e) {
        span.textContent = '••••••••';
        this.textContent = 'Show';
        alert('Could not load password: ' + e.message);
      } finally {
        this.disabled = false;
      }
    } else {
      span.textContent = '••••••••';
      this.textContent = 'Show';
    }
  });
});
</script>
<%- include('../partials/footer') %>
