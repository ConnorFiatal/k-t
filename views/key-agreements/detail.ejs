<%- include('../partials/header') %>
<div class="page-header no-print">
  <div>
    <h1>Key Agreement</h1>
    <p class="text-muted">Key copy <%= agreement.stamp_number %> — issued to <%= agreement.first_name %> <%= agreement.last_name %></p>
  </div>
  <div class="btn-group no-print">
    <button class="btn btn-primary print-btn">🖨 Print Agreement</button>
    <% if (!agreement.returned_date) { %>
      <a href="/key-agreements/<%= agreement.id %>/upload" class="btn btn-outline" id="uploadLink">Upload Signed Copy</a>
    <% } %>
    <a href="/key-agreements" class="btn btn-ghost">← Agreements</a>
  </div>
</div>

<!-- ─── PRINTABLE AGREEMENT ─────────────────────────────────────────────── -->
<div class="agreement-doc">

  <div class="agreement-header">
    <div class="agreement-brand"><%= appName %></div>
    <div class="agreement-title">Key Issuance Agreement &amp; Acknowledgment</div>
    <div class="agreement-meta">Agreement #<%= agreement.id %> &nbsp;·&nbsp; Generated <%= new Date().toLocaleDateString() %></div>
  </div>

  <div class="agreement-section">
    <div class="agreement-section-title">Key Copy Details</div>
    <table class="agreement-table">
      <tr>
        <th>Stamp Number</th>
        <td><strong><%= agreement.stamp_number %></strong></td>
        <th>Key Type</th>
        <td><%= agreement.key_number %></td>
      </tr>
      <tr>
        <th>Key System</th>
        <td><%= agreement.system_name %></td>
        <th>Level</th>
        <td><span class="badge badge-level-<%= (agreement.level||'change').toLowerCase() %>"><%= agreement.level %></span></td>
      </tr>
      <tr>
        <th>Keyway</th>
        <td><%= agreement.keyway || '—' %></td>
        <th>Ring</th>
        <td><%= agreement.ring_number || '—' %></td>
      </tr>
    </table>
  </div>

  <div class="agreement-section">
    <div class="agreement-section-title">Issued To</div>
    <table class="agreement-table">
      <tr>
        <th>Full Name</th>
        <td><strong><%= agreement.first_name %> <%= agreement.last_name %></strong></td>
        <th>Employee ID</th>
        <td><%= agreement.employee_id || '—' %></td>
      </tr>
      <tr>
        <th>Department</th>
        <td><%= agreement.department || '—' %></td>
        <th>Title</th>
        <td><%= agreement.title || '—' %></td>
      </tr>
      <tr>
        <th>Issue Date</th>
        <td><strong><%= agreement.issued_date %></strong></td>
        <th>Expiry Date</th>
        <td class="<%= agreement.expiry_date && !agreement.returned_date && new Date(agreement.expiry_date) < new Date() ? 'text-danger' : '' %>">
          <strong><%= agreement.expiry_date || 'No expiry (permanent staff)' %></strong>
        </td>
      </tr>
      <% if (agreement.returned_date) { %>
      <tr>
        <th>Returned Date</th>
        <td colspan="3"><strong><%= agreement.returned_date %></strong></td>
      </tr>
      <% } %>
    </table>
  </div>

  <div class="agreement-section">
    <div class="agreement-section-title">Acknowledgment and Conditions of Use</div>
    <div class="agreement-ack-text">
      <% if (agreement.acknowledgment_text) { %>
        <%= agreement.acknowledgment_text %>
      <% } else { %>
        I acknowledge receipt of the key copy detailed above. I understand that:
        (1) I am personally responsible for the safekeeping of this key at all times.
        (2) I must immediately notify the administration in the event of loss or theft.
        (3) I must not duplicate this key or allow unauthorized use.
        (4) I must return this key immediately upon request or upon termination of my employment or contract.
        (5) Failure to return this key may result in disciplinary action and/or cost recovery for re-keying.
      <% } %>
    </div>
  </div>

  <div class="agreement-section agreement-signatures">
    <div class="agreement-sig-block">
      <div class="agreement-sig-label">Recipient Signature</div>
      <div class="agreement-sig-line"></div>
      <div class="agreement-sig-name"><%= agreement.first_name %> <%= agreement.last_name %></div>
      <div class="agreement-sig-date">Date: ____________________</div>
    </div>
    <div class="agreement-sig-block">
      <div class="agreement-sig-label">Authorized By</div>
      <div class="agreement-sig-line"></div>
      <div class="agreement-sig-name">Administrator</div>
      <div class="agreement-sig-date">Date: ____________________</div>
    </div>
  </div>

  <div class="agreement-footer">
    This document was generated by <%= appName %> on <%= new Date().toLocaleString() %>.
    Agreement ID: <%= agreement.id %>. Please retain a signed copy for your records.
  </div>
</div>

<!-- Upload signed scan (screen only) -->
<% if (!agreement.returned_date || agreement.signed_agreement_filename) { %>
<div class="card no-print" style="margin-top:1.5rem">
  <div class="card-header">
    <h2>Signed Agreement Scan</h2>
  </div>
  <div class="card-section">
    <% if (agreement.signed_agreement_filename) { %>
      <p style="margin-bottom:.75rem">
        <a href="/uploads/agreements/<%= agreement.signed_agreement_filename %>" target="_blank" class="btn btn-outline btn-sm">📎 View Current Signed Copy</a>
      </p>
    <% } %>
    <% if (!agreement.returned_date) { %>
    <form action="/key-agreements/<%= agreement.id %>/upload" method="POST" enctype="multipart/form-data" style="display:flex;gap:.75rem;align-items:center">
      <input type="file" name="signed_agreement" accept=".pdf,.png,.jpg,.jpeg" required>
      <button type="submit" class="btn btn-outline">Upload Signed Copy</button>
    </form>
    <% } %>
  </div>
</div>
<% } %>
<%- include('../partials/footer') %>
