<%- include('../partials/header') %>
<div class="page-header">
  <h1><%= title %></h1>
  <a href="/safes" class="btn btn-ghost">← Back</a>
</div>

<div class="card card-form">
  <form action="<%= action %>" method="POST">
    <div class="form-row">
      <div class="form-group">
        <label for="name">Safe Name <span class="required">*</span></label>
        <input type="text" id="name" name="name" required value="<%= safe ? safe.name : '' %>" placeholder="e.g. Main Office Safe">
      </div>
      <div class="form-group">
        <label for="location">Location</label>
        <input type="text" id="location" name="location" value="<%= safe ? (safe.location || '') : '' %>" placeholder="e.g. Manager's Office">
      </div>
    </div>
    <div class="form-group">
      <label for="combination">Combination <span class="required">*</span></label>
      <input type="text" id="combination" name="combination" required value="<%= safe ? safe.combination : '' %>" placeholder="e.g. 14-27-36" autocomplete="off">
      <p class="field-hint">This is stored in the database. Ensure the database file has restricted filesystem permissions.</p>
    </div>
    <div class="form-group">
      <label for="notes">Notes</label>
      <textarea id="notes" name="notes" rows="3"><%= safe ? (safe.notes || '') : '' %></textarea>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary"><%= safe ? 'Save Changes' : 'Create Safe' %></button>
      <a href="/safes<%= safe ? '/' + safe.id : '' %>" class="btn btn-ghost">Cancel</a>
    </div>
  </form>
</div>
<%- include('../partials/footer') %>
