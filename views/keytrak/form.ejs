<%- include('../partials/header') %>
<div class="page-header">
  <h1><%= title %></h1>
  <a href="/keytrak" class="btn btn-ghost">← Back</a>
</div>

<div class="card card-form">
  <form action="<%= action %>" method="POST">
    <div class="form-row">
      <div class="form-group">
        <label for="ring_number">Ring Number <span class="required">*</span></label>
        <input type="text" id="ring_number" name="ring_number" required value="<%= keyring ? keyring.ring_number : '' %>" placeholder="e.g. K-001">
      </div>
      <div class="form-group">
        <label for="location">Location</label>
        <input type="text" id="location" name="location" value="<%= keyring ? (keyring.location || '') : '' %>" placeholder="e.g. KeyTrak Cabinet A">
      </div>
    </div>
    <div class="form-group">
      <label for="description">Description</label>
      <input type="text" id="description" name="description" value="<%= keyring ? (keyring.description || '') : '' %>" placeholder="e.g. Master keys – Building 1">
    </div>
    <div class="form-group">
      <label for="notes">Notes</label>
      <textarea id="notes" name="notes" rows="3"><%= keyring ? (keyring.notes || '') : '' %></textarea>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary"><%= keyring ? 'Save Changes' : 'Create Keyring' %></button>
      <a href="/keytrak<%= keyring ? '/' + keyring.id : '' %>" class="btn btn-ghost">Cancel</a>
    </div>
  </form>
</div>
<%- include('../partials/footer') %>
