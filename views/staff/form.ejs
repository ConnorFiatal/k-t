<%- include('../partials/header') %>
<div class="page-header">
  <h1><%= title %></h1>
  <a href="/staff" class="btn btn-ghost">← Back</a>
</div>

<div class="card card-form">
  <form action="<%= action %>" method="POST">
    <div class="form-row">
      <div class="form-group">
        <label for="first_name">First Name <span class="required">*</span></label>
        <input type="text" id="first_name" name="first_name" required value="<%= staff ? staff.first_name : '' %>">
      </div>
      <div class="form-group">
        <label for="last_name">Last Name <span class="required">*</span></label>
        <input type="text" id="last_name" name="last_name" required value="<%= staff ? staff.last_name : '' %>">
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label for="employee_id">Employee ID</label>
        <input type="text" id="employee_id" name="employee_id" value="<%= staff ? (staff.employee_id || '') : '' %>">
      </div>
      <div class="form-group">
        <label for="start_date">Start Date</label>
        <input type="date" id="start_date" name="start_date" value="<%= staff ? (staff.start_date || '') : '' %>">
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label for="department">Department</label>
        <input type="text" id="department" name="department" value="<%= staff ? (staff.department || '') : '' %>">
      </div>
      <div class="form-group">
        <label for="title">Job Title</label>
        <input type="text" id="title" name="title" value="<%= staff ? (staff.title || '') : '' %>">
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" value="<%= staff ? (staff.email || '') : '' %>">
      </div>
      <div class="form-group">
        <label for="phone">Phone</label>
        <input type="tel" id="phone" name="phone" value="<%= staff ? (staff.phone || '') : '' %>">
      </div>
    </div>
    <div class="form-group">
      <label for="notes">Notes</label>
      <textarea id="notes" name="notes" rows="3"><%= staff ? (staff.notes || '') : '' %></textarea>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary"><%= staff ? 'Save Changes' : 'Create Staff Member' %></button>
      <a href="/staff<%= staff ? '/' + staff.id : '' %>" class="btn btn-ghost">Cancel</a>
    </div>
  </form>
</div>
<%- include('../partials/footer') %>
