<%- include('../partials/header') %>
<div class="page-header">
  <div>
    <h1><%= staff.first_name %> <%= staff.last_name %>
      <span class="badge badge-<%= staff.status === 'active' ? 'green' : 'red' %> badge-lg"><%= staff.status %></span>
    </h1>
    <p class="text-muted"><%= staff.title || '' %><%= staff.department ? ` · ${staff.department}` : '' %></p>
  </div>
  <div class="btn-group">
    <a href="/staff/<%= staff.id %>/edit" class="btn btn-outline">Edit</a>
    <% if (staff.status === 'active') { %>
      <a href="/staff/<%= staff.id %>/termination" class="btn btn-danger-outline">Termination Checklist</a>
    <% } else { %>
      <form action="/staff/<%= staff.id %>/reactivate" method="POST" style="display:inline">
        <button type="submit" class="btn btn-outline" onclick="return confirm('Reactivate this staff member?')">Reactivate</button>
      </form>
    <% } %>
    <a href="/staff" class="btn btn-ghost">← Back</a>
  </div>
</div>

<div class="detail-grid">
  <div class="card">
    <div class="card-header"><h2>Profile</h2></div>
    <table class="info-table">
      <tr><th>Employee ID</th><td><%= staff.employee_id || '—' %></td></tr>
      <tr><th>Department</th><td><%= staff.department || '—' %></td></tr>
      <tr><th>Title</th><td><%= staff.title || '—' %></td></tr>
      <tr><th>Email</th><td><%= staff.email ? `<a href="mailto:${staff.email}">${staff.email}</a>` : '—' %></td></tr>
      <tr><th>Phone</th><td><%= staff.phone || '—' %></td></tr>
      <tr><th>Start Date</th><td><%= staff.start_date || '—' %></td></tr>
      <tr><th>Added</th><td><%= staff.created_at %></td></tr>
      <% if (staff.notes) { %><tr><th>Notes</th><td><%= staff.notes %></td></tr><% } %>
    </table>
  </div>

  <div>
    <div class="card">
      <div class="card-header">
        <h2>Safe Access <span class="count-badge"><%= safeAccess.length %></span></h2>
      </div>
      <% if (safeAccess.length === 0) { %>
        <p class="empty-state-sm">No safe access.</p>
      <% } else { %>
      <table class="table table-sm">
        <thead><tr><th>Safe</th><th>Location</th><th>Granted</th><th>By</th></tr></thead>
        <tbody>
          <% safeAccess.forEach(a => { %>
          <tr>
            <td><a href="/safes/<%= a.safe_id %>"><%= a.safe_name %></a></td>
            <td class="text-muted"><%= a.location || '—' %></td>
            <td class="text-muted text-sm"><%= a.granted_at %></td>
            <td class="text-muted"><%= a.granted_by %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>

    <div class="card">
      <div class="card-header">
        <h2>Physical Keyring Authorizations <span class="count-badge"><%= keyrings.length %></span></h2>
      </div>
      <% if (keyrings.length === 0) { %>
        <p class="empty-state-sm">No keyring authorizations.</p>
      <% } else { %>
      <table class="table table-sm">
        <thead><tr><th>Ring #</th><th>Description</th><th>Granted</th><th>By</th></tr></thead>
        <tbody>
          <% keyrings.forEach(k => { %>
          <tr>
            <td><a href="/keytrak/<%= k.keyring_id %>"><%= k.ring_number %></a></td>
            <td class="text-muted"><%= k.description || '—' %></td>
            <td class="text-muted text-sm"><%= k.granted_at %></td>
            <td class="text-muted"><%= k.granted_by %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>

    <div class="card">
      <div class="card-header">
        <h2>System Account Access <span class="count-badge"><%= systemAccounts.length %></span></h2>
      </div>
      <% if (systemAccounts.length === 0) { %>
        <p class="empty-state-sm">No system account access.</p>
      <% } else { %>
      <table class="table table-sm">
        <thead><tr><th>System</th><th>Username</th><th>Category</th><th>Granted</th></tr></thead>
        <tbody>
          <% systemAccounts.forEach(a => { %>
          <tr>
            <td><a href="/system-accounts/<%= a.account_id %>"><%= a.system_name %></a></td>
            <td class="text-muted"><%= a.account_username %></td>
            <td><%= a.category ? `<span class="badge badge-outline">${a.category}</span>` : '—' %></td>
            <td class="text-muted text-sm"><%= a.granted_at %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
