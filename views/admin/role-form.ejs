<%- include('../partials/header') %>
<div class="page-header">
  <h1><%= title %></h1>
  <a href="/admin/roles" class="btn btn-ghost">← Back</a>
</div>

<form action="<%= role ? `/admin/roles/${role.id}/edit` : '/admin/roles' %>" method="POST">
  <div class="card card-form" style="margin-bottom:1.5rem">
    <div class="form-group">
      <label for="label">Role Name <span class="required">*</span></label>
      <input type="text" id="label" name="label" required value="<%= role ? role.label : '' %>"
             placeholder="e.g. Front Desk Staff" autocomplete="off">
      <% if (!role) { %>
        <p class="field-hint">A machine-readable key will be generated automatically from the name.</p>
      <% } %>
    </div>
    <div class="form-group">
      <label for="description">Description</label>
      <input type="text" id="description" name="description" value="<%= role ? (role.description || '') : '' %>"
             placeholder="What can users in this role do?" autocomplete="off">
    </div>
  </div>

  <div class="card card-form">
    <div style="padding:1.25rem 1.5rem 0.5rem;border-bottom:1px solid var(--color-border)">
      <h2 style="font-size:1rem;margin:0">Permissions</h2>
      <p class="field-hint" style="margin:0.25rem 0 0">Select the specific actions users with this role can perform.</p>
    </div>

    <div style="padding:1.25rem 1.5rem">
      <div style="display:flex;gap:0.75rem;margin-bottom:1.25rem">
        <button type="button" class="btn btn-sm btn-outline" id="selectAll">Select All</button>
        <button type="button" class="btn btn-sm btn-outline" id="clearAll">Clear All</button>
      </div>

      <div class="permission-grid">
        <% permissionGroups.forEach(group => { %>
        <div class="permission-group">
          <div class="permission-group-header">
            <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;font-weight:600;font-size:0.85rem">
              <input type="checkbox" class="group-toggle"
                     data-group="<%= group.label.toLowerCase().replace(/[^a-z0-9]/g,'_') %>"
                     <%= group.permissions.every(p => rolePerms.includes(p.key)) ? 'checked' : '' %>>
              <%= group.label %>
            </label>
          </div>
          <div class="permission-list">
            <% group.permissions.forEach(perm => { %>
            <label class="permission-item">
              <input type="checkbox" name="permissions" value="<%= perm.key %>"
                     class="perm-check group-<%= group.label.toLowerCase().replace(/[^a-z0-9]/g,'_') %>"
                     <%= rolePerms.includes(perm.key) ? 'checked' : '' %>>
              <span class="perm-label"><%= perm.label %></span>
              <span class="perm-key"><%= perm.key %></span>
            </label>
            <% }) %>
          </div>
        </div>
        <% }) %>
      </div>
    </div>

    <div class="form-actions" style="border-top:1px solid var(--color-border);padding:1.25rem 1.5rem">
      <button type="submit" class="btn btn-primary"><%= role ? 'Save Changes' : 'Create Role' %></button>
      <a href="/admin/roles" class="btn btn-ghost">Cancel</a>
    </div>
  </div>
</form>

<style>
.permission-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1rem;
}
.permission-group {
  border: 1px solid var(--color-border);
  border-radius: 6px;
  overflow: hidden;
}
.permission-group-header {
  background: var(--color-bg-secondary, #f8f9fa);
  padding: 0.6rem 0.85rem;
  border-bottom: 1px solid var(--color-border);
}
.permission-list {
  padding: 0.5rem 0.85rem 0.75rem;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}
.permission-item {
  display: grid;
  grid-template-columns: 16px 1fr;
  grid-template-rows: auto auto;
  column-gap: 0.5rem;
  cursor: pointer;
  padding: 0.15rem 0;
}
.permission-item input { grid-row: 1 / 3; margin-top: 3px; }
.perm-label { font-size: 0.85rem; line-height: 1.3; }
.perm-key { font-size: 0.72rem; font-family: monospace; color: var(--color-text-secondary); }
</style>

<script>
function setAll(checked) {
  document.querySelectorAll('input[name="permissions"]').forEach(cb => cb.checked = checked);
  document.querySelectorAll('.group-toggle').forEach(cb => cb.checked = checked);
}
function toggleGroup(toggle) {
  const cls = 'group-' + toggle.dataset.group;
  document.querySelectorAll('.' + cls).forEach(cb => cb.checked = toggle.checked);
}
function updateGroupToggle(perm) {
  const cls = [...perm.classList].find(c => c.startsWith('group-') && c !== 'perm-check');
  if (!cls) return;
  const group = cls.replace('group-', '');
  const boxes = document.querySelectorAll('.' + cls);
  const toggle = document.querySelector('[data-group="' + group + '"]');
  if (toggle) toggle.checked = [...boxes].every(b => b.checked);
}
document.getElementById('selectAll').addEventListener('click', () => setAll(true));
document.getElementById('clearAll').addEventListener('click', () => setAll(false));
document.querySelectorAll('.group-toggle').forEach(t => t.addEventListener('change', () => toggleGroup(t)));
document.querySelectorAll('.perm-check').forEach(p => p.addEventListener('change', () => updateGroupToggle(p)));
</script>
<%- include('../partials/footer') %>
