<%- include('../partials/header') %>
<div class="page-header">
  <h1>Plan Settings</h1>
</div>

<%
  const featureList = [
    { key: 'floor_plans',       label: 'Floor Plan Management',   desc: 'Interactive building floor plans with door pin overlays.' },
    { key: 'key_agreements',    label: 'Key Agreement Workflows',  desc: 'Issue, track, and store signed key custody agreements.' },
    { key: 'ring_checkout',     label: 'Ring Checkout System',     desc: 'Key-ring check-in / check-out at front desks.' },
    { key: 'csv_import_export', label: 'CSV Import & Export',      desc: 'Bulk import records and export all data to CSV.' },
    { key: 'email_alerts',      label: 'Email Overdue Alerts',     desc: 'Automated email notifications for overdue or expiring keys.' },
    { key: 'priority_support',  label: 'Priority Support',         desc: 'Dedicated support channel with SLA response times.' },
  ];

  const limitList = [
    { key: 'max_admin_users',      label: 'Max Admin Users',      hint: '0 = unlimited' },
    { key: 'max_buildings',        label: 'Max Buildings',         hint: '0 = unlimited' },
    { key: 'audit_retention_days', label: 'Audit Log Retention',  hint: 'days' },
  ];
%>

<%# ── Feature Modules ──────────────────────────────────────────────────── %>
<div class="card" style="margin-bottom:1.5rem">
  <div style="padding:1.25rem 1.5rem 0.75rem;border-bottom:1px solid var(--color-border)">
    <h2 style="font-size:1rem;margin:0">Feature Modules</h2>
  </div>
  <div style="padding:1rem 1.5rem">
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:0.6rem">
      <% featureList.forEach(f => {
        const on = planLicensed[f.key] === '1';
      %>
      <div class="feature-status-card <%= on ? 'feature-status-card--on' : 'feature-status-card--off' %>">
        <div class="feature-status-indicator">
          <% if (on) { %>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
          <% } else { %>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          <% } %>
        </div>
        <div>
          <div style="font-weight:600;font-size:0.875rem"><%= f.label %></div>
          <div class="text-muted" style="font-size:0.78rem;margin-top:0.15rem"><%= f.desc %></div>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
</div>

<%# ── Limits ────────────────────────────────────────────────────────────── %>
<div class="card" style="margin-bottom:1.5rem">
  <div style="padding:1.25rem 1.5rem 0.75rem;border-bottom:1px solid var(--color-border)">
    <h2 style="font-size:1rem;margin:0">Limits</h2>
  </div>
  <div style="padding:1.25rem 1.5rem">
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:1rem">
      <% limitList.forEach(lf => {
        const val = planSettings[lf.key];
        const display = (val === '0' || val === undefined || val === '') ? 'Unlimited' : val + (lf.hint === 'days' ? ' days' : '');
      %>
      <div class="limit-display-card">
        <div class="limit-display-value"><%= display %></div>
        <div style="font-weight:500;font-size:0.85rem"><%= lf.label %></div>
      </div>
      <% }); %>
    </div>
  </div>
</div>

<style>
.feature-status-card {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
  border: 1px solid var(--color-border);
  border-radius: 8px;
  padding: 0.8rem 1rem;
}
.feature-status-card--on {
  border-color: #16a34a33;
  background: #f0fdf4;
}
.feature-status-card--off {
  opacity: 0.55;
  background: var(--color-bg-muted, #f8f9fa);
}
.feature-status-indicator {
  flex-shrink: 0;
  width: 24px;
  height: 24px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 0.1rem;
}
.feature-status-card--on  .feature-status-indicator { background: #16a34a; color: #fff; }
.feature-status-card--off .feature-status-indicator { background: var(--color-border); color: var(--color-muted); }

.limit-display-card {
  border: 1px solid var(--color-border);
  border-radius: 8px;
  padding: 1rem 1.1rem;
}
.limit-display-value {
  font-size: 1.6rem;
  font-weight: 700;
  line-height: 1.1;
  margin-bottom: 0.2rem;
  color: var(--color-primary, #2563eb);
}

</style>
<%- include('../partials/footer') %>
