<%- include('../partials/header') %>
<div class="page-header">
  <h1>Change Password — <%= targetUser.username %></h1>
  <a href="/admin/users" class="btn btn-ghost">← Back</a>
</div>

<div class="card card-form">
  <form action="/admin/users/<%= targetUser.id %>/change-password" method="POST">
    <div class="form-group">
      <label for="password">New Password <span class="required">*</span></label>
      <input type="password" id="password" name="password" required autocomplete="new-password" minlength="8">
      <p class="field-hint">Minimum 8 characters.</p>
    </div>
    <div class="form-group">
      <label for="confirm_password">Confirm New Password <span class="required">*</span></label>
      <input type="password" id="confirm_password" name="confirm_password" required autocomplete="new-password">
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Update Password</button>
      <a href="/admin/users" class="btn btn-ghost">Cancel</a>
    </div>
  </form>
</div>
<%- include('../partials/footer') %>
