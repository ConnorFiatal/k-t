<%- include('../partials/header') %>
<div class="page-header">
  <h1><%= title %></h1>
  <a href="/admin/users" class="btn btn-ghost">← Back</a>
</div>

<div class="card card-form">
  <form action="/admin/users/<%= targetUser.id %>/edit-role" method="POST">
    <div class="form-group">
      <label for="role_id">Role</label>
      <select id="role_id" name="role_id">
        <option value="">— No role (no access) —</option>
        <% roles.forEach(r => { %>
          <option value="<%= r.id %>" <%= targetUser.role_id === r.id ? 'selected' : '' %>>
            <%= r.label %><%= r.description ? ` — ${r.description}` : '' %>
          </option>
        <% }) %>
      </select>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Save Role</button>
      <a href="/admin/users" class="btn btn-ghost">Cancel</a>
    </div>
  </form>
</div>
<%- include('../partials/footer') %>
