<%- include('../partials/header') %>
<div class="page-header">
  <h1><%= title %></h1>
  <a href="/key-systems" class="btn btn-ghost">← Back</a>
</div>

<div class="card card-form">
  <form action="<%= action %>" method="POST">
    <div class="form-row">
      <div class="form-group">
        <label for="name">System Name <span class="required">*</span></label>
        <input type="text" id="name" name="name" required value="<%= system ? system.name : '' %>" placeholder="e.g. Building A Master System">
      </div>
      <div class="form-group">
        <label for="manufacturer">Manufacturer</label>
        <input type="text" id="manufacturer" name="manufacturer" value="<%= system ? (system.manufacturer || '') : '' %>" placeholder="e.g. Schlage, Best, Medeco">
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label for="keyway">System Keyway</label>
        <input type="text" id="keyway" name="keyway" value="<%= system ? (system.keyway || '') : '' %>" placeholder="e.g. Schlage C, Best A, Corbin 59">
      </div>
    </div>
    <div class="form-group">
      <label for="description">Description</label>
      <textarea id="description" name="description" rows="2"><%= system ? (system.description || '') : '' %></textarea>
    </div>
    <div class="form-group">
      <label for="notes">Notes</label>
      <textarea id="notes" name="notes" rows="3"><%= system ? (system.notes || '') : '' %></textarea>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary"><%= system ? 'Save Changes' : 'Create Key System' %></button>
      <a href="/key-systems<%= system ? '/' + system.id : '' %>" class="btn btn-ghost">Cancel</a>
    </div>
  </form>
</div>
<%- include('../partials/footer') %>
