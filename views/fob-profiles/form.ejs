<%- include('../partials/header') %>
<div class="page-header">
  <h1><%= title %></h1>
  <a href="/fob-profiles" class="btn btn-ghost">← Back</a>
</div>

<div class="card card-form">
  <form action="<%= action %>" method="POST">
    <div class="form-group">
      <label for="name">Profile Name <span class="required">*</span></label>
      <input type="text" id="name" name="name" required value="<%= profile ? profile.name : '' %>" placeholder="e.g. Standard Employee, Executive, Facilities">
    </div>
    <div class="form-group">
      <label for="description">Description</label>
      <textarea id="description" name="description" rows="2"><%= profile ? (profile.description || '') : '' %></textarea>
    </div>
    <div class="form-group">
      <label for="notes">Notes</label>
      <textarea id="notes" name="notes" rows="3"><%= profile ? (profile.notes || '') : '' %></textarea>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary"><%= profile ? 'Save Changes' : 'Create Profile' %></button>
      <a href="/fob-profiles<%= profile ? '/' + profile.id : '' %>" class="btn btn-ghost">Cancel</a>
    </div>
  </form>
</div>
<%- include('../partials/footer') %>
