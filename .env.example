# ─── Infisical (recommended) ─────────────────────────────────────────────────
# When these are set, all other secrets are pulled from Infisical at startup.
# Create a Machine Identity in your Infisical project → Access Control → Machine Identities,
# enable Universal Auth, and copy the Client ID + Client Secret here.
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_PROJECT_ID=
# Must match the Infisical environment slug (e.g. dev, staging, prod).
# Falls back to NODE_ENV, then "dev" if unset.
INFISICAL_ENV=dev

# ─── Required secrets (fallback — used only when Infisical vars are absent) ──
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ─── Application ─────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# ─── Email / SMTP ────────────────────────────────────────────────────────────
# Leave SMTP_HOST blank to disable outbound email (alerts are still logged).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=KeyDog <noreply@example.com>

# ─── Plan / Licensing (optional overrides) ───────────────────────────────────
# Bearer token for the plan API endpoint
PLAN_API_KEY=

# Override licensed features: set to 1 to enable, 0 to disable
# PLAN_LICENSED_FLOOR_PLANS=1
# PLAN_LICENSED_KEY_AGREEMENTS=1
# PLAN_LICENSED_RING_CHECKOUT=1
# PLAN_LICENSED_CSV_IMPORT_EXPORT=1
# PLAN_LICENSED_EMAIL_ALERTS=1
# PLAN_LICENSED_PRIORITY_SUPPORT=1

# Override plan limits
# PLAN_MAX_ADMIN_USERS=10
# PLAN_MAX_BUILDINGS=5
# PLAN_AUDIT_RETENTION_DAYS=365
